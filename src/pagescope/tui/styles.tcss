/* PageScope TUI -- DevTools dark theme */

Screen {
    background: #0f172a;
}

#header-bar {
    dock: top;
    height: 3;
    background: #1e293b;
    border-bottom: solid #334155;
    padding: 0 1;
}

#header-bar Label {
    color: #e2e8f0;
}

#url-input {
    width: 1fr;
    height: 1;
    background: transparent;
    border: none;
    color: #6366f1;
}

#url-input:focus {
    background: #162036;
    color: #e2e8f0;
}

#url-input.hidden {
    display: none;
}

#har-input {
    width: 1fr;
    height: 1;
    background: #162036;
    border: none;
    color: #e2e8f0;
}

#har-input.hidden {
    display: none;
}

#status-label {
    color: #94a3b8;
    width: 1fr;
}

/* Toggle indicators -- right side of header bar */
.toggle-off {
    color: #334155;
    margin-left: 1;
    padding: 0 1;
}

.toggle-on {
    color: #0f172a;
    background: #f59e0b;
    text-style: bold;
    margin-left: 1;
    padding: 0 1;
}

/* Tab content area */
ContentSwitcher {
    height: 1fr;
}

/* ── Unified button bar styles ──
   All sub-tab and filter buttons use the same text+underline style
   to match the top-level TabbedContent tabs. */

.tab-bar {
    height: 3;
    background: #0f172a;
    border-bottom: solid #334155;
    layout: horizontal;
    padding: 0 1;
}

.tab-bar Button {
    height: 3;
    background: transparent;
    color: #64748b;
    border: none;
    padding: 0 2;
    min-width: 0;
}

.tab-bar Button:hover {
    color: #e2e8f0;
    background: transparent;
}

.tab-bar Button.active {
    color: #6366f1;
    text-style: bold underline;
    background: transparent;
}

/* Filter bars -- slightly different bg to separate from view tabs */
.filter-bar {
    height: 3;
    background: #1e293b;
    border-bottom: solid #334155;
    layout: horizontal;
    padding: 0 1;
}

.filter-bar Button {
    height: 3;
    background: transparent;
    color: #64748b;
    border: none;
    padding: 0 2;
    min-width: 0;
}

.filter-bar Button:hover {
    color: #e2e8f0;
    background: transparent;
}

.filter-bar Button.active {
    color: #6366f1;
    text-style: bold underline;
    background: transparent;
}

/* Search inputs in bars */
.filter-bar Input,
.tab-bar Input {
    width: 30;
    height: 1;
    dock: right;
    background: #162036;
    border: none;
    color: #e2e8f0;
}

/* ── Network Tab ── */

#network-container {
    height: 1fr;
}

#filter-bar {
    height: 3;
    background: #1e293b;
    border-bottom: solid #334155;
    layout: horizontal;
    padding: 0 1;
}

#filter-bar Button {
    height: 3;
    background: transparent;
    color: #64748b;
    border: none;
    padding: 0 2;
    min-width: 0;
}

#filter-bar Button:hover {
    color: #e2e8f0;
    background: transparent;
}

#filter-bar Button.active {
    color: #6366f1;
    text-style: bold underline;
    background: transparent;
}

#filter-input {
    width: 30;
    height: 1;
    dock: right;
    background: #162036;
    border: none;
    color: #e2e8f0;
}

/* Main split: request table + detail panel */
#main-split {
    height: 1fr;
}

/* Request table */
#request-table {
    height: 1fr;
    min-height: 10;
}

DataTable {
    height: 1fr;
}

DataTable > .datatable--header {
    background: #1e293b;
    color: #94a3b8;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #334155;
}

DataTable > .datatable--even-row {
    background: #0f172a;
}

DataTable > .datatable--odd-row {
    background: #131c2e;
}

/* Detail panel */
#detail-panel {
    height: 12;
    background: #1e293b;
    border-top: solid #334155;
    display: none;
}

#detail-panel.visible {
    display: block;
}

#detail-tabs {
    height: 3;
    background: #0f172a;
    border-bottom: solid #334155;
    layout: horizontal;
}

#detail-tabs Button {
    height: 3;
    background: transparent;
    color: #64748b;
    border: none;
    padding: 0 2;
    min-width: 0;
}

#detail-tabs Button:hover {
    color: #e2e8f0;
}

#detail-tabs Button.active {
    color: #6366f1;
    text-style: bold underline;
    background: transparent;
}

#detail-content {
    height: 1fr;
    padding: 1;
    overflow-y: auto;
}

#detail-content Static {
    color: #e2e8f0;
}

/* Summary bar */
#summary-bar {
    dock: bottom;
    height: 1;
    background: #1e293b;
    border-top: solid #334155;
    padding: 0 1;
    layout: horizontal;
}

#summary-bar Label {
    color: #94a3b8;
    margin-right: 3;
}

/* ── Console Tab ── */

#console-filter-bar {
    height: 3;
    background: #1e293b;
    border-bottom: solid #334155;
    layout: horizontal;
    padding: 0 1;
}

#console-filter-bar Button {
    height: 3;
    background: transparent;
    color: #64748b;
    border: none;
    padding: 0 2;
    min-width: 0;
}

#console-filter-bar Button:hover {
    color: #e2e8f0;
    background: transparent;
}

#console-filter-bar Button.active {
    color: #6366f1;
    text-style: bold underline;
    background: transparent;
}

#console-search {
    width: 30;
    height: 1;
    dock: right;
    background: #162036;
    border: none;
    color: #e2e8f0;
}

#console-main {
    height: 1fr;
}

#console-table {
    height: 1fr;
    min-height: 10;
}

#console-detail {
    height: 12;
    background: #1e293b;
    border-top: solid #334155;
    display: none;
    padding: 1;
    overflow-y: auto;
}

#console-detail.visible {
    display: block;
}

#console-detail-content {
    color: #e2e8f0;
}

/* Console eval input bar */
#console-input-bar {
    dock: bottom;
    height: 3;
    background: #131c2e;
    border-top: solid #334155;
    padding: 0 1;
    layout: horizontal;
}

#console-input-bar.hidden {
    display: none;
}

#console-prompt {
    width: 3;
    height: 3;
    color: #22d3ee;
    text-style: bold;
    content-align-vertical: middle;
    padding: 1 0 0 0;
}

#console-eval-input {
    width: 1fr;
    height: 1;
    background: #0f172a;
    border: none;
    color: #e2e8f0;
}

/* Editor toggle buttons -- minimal style */
.editor-btn {
    width: 5;
    height: 3;
    background: #1e293b;
    color: #94a3b8;
    border: none;
    min-width: 0;
    padding: 0 1;
}

#console-expand-btn {
    dock: right;
    width: 3;
    height: 1;
    color: #94a3b8;
    background: #1e293b;
    text-align: center;
    padding: 0;
}

#console-expand-btn:hover {
    color: #e2e8f0;
    background: #334155;
}

.editor-btn:hover {
    color: #e2e8f0;
    background: #334155;
}

/* Expanded JS editor panel */
#console-editor-panel {
    dock: bottom;
    height: 50%;
    background: #131c2e;
    border-top: solid #334155;
}

#console-editor-panel.hidden {
    display: none;
}

#console-editor-bar {
    height: 3;
    background: #1e293b;
    border-bottom: solid #334155;
    padding: 0 1;
    layout: horizontal;
}

#console-editor-label {
    width: 1fr;
    height: 3;
    color: #22d3ee;
    content-align-vertical: middle;
    padding: 1 0 0 0;
}

#console-editor-textarea {
    height: 1fr;
    background: #0f172a;
}

#console-summary {
    dock: bottom;
    height: 1;
    background: #1e293b;
    border-top: solid #334155;
    padding: 0 1;
    layout: horizontal;
}

#console-summary Label {
    color: #94a3b8;
    margin-right: 3;
}


    width: 30;
    height: 1;
    dock: right;
    background: #162036;
    border: none;
    color: #e2e8f0;
}

#ws-main {
    height: 1fr;
}

#ws-conn-table {
    height: auto;
    max-height: 8;
    min-height: 4;
}

#ws-frame-table {
    height: 1fr;
    min-height: 6;
}

#ws-detail {
    height: 12;
    background: #1e293b;
    border-top: solid #334155;
    display: none;
    padding: 1;
    overflow-y: auto;
}

#ws-detail.visible {
    display: block;
}

#ws-detail-content {
    color: #e2e8f0;
}

#ws-summary {
    dock: bottom;
    height: 1;
    background: #1e293b;
    border-top: solid #334155;
    padding: 0 1;
    layout: horizontal;
}

#ws-summary Label {
    color: #94a3b8;
    margin-right: 3;
}

/* ── Legend Overlay ── */

#legend-overlay {
    layer: overlay;
    dock: right;
    width: 60;
    height: auto;
    max-height: 80%;
    background: #1e293b;
    border: solid #334155;
    padding: 1 2;
    color: #e2e8f0;
    margin: 4 2;
}

#legend-overlay.hidden {
    display: none;
}

/* Footer keybindings */
Footer {
    background: #1e293b;
}
